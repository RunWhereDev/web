---
import { readFile } from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import manifest from "../../../data/generated/manifest.json";
import type { Artifact } from "../../../../shared/types";

export function getStaticPaths() {
  return manifest.models.flatMap((model) =>
    model.clouds.map((cloud) => ({
      params: { model: model.slug, cloud }
    }))
  );
}

const modelSlug = Astro.params.model!;
const cloudSlug = Astro.params.cloud!;
const artifactPath = path.join(process.cwd(), "src/data/generated/compositions", modelSlug, `${cloudSlug}.json`);
const artifact = JSON.parse(await readFile(artifactPath, "utf8")) as Artifact;
const pageTitle = `${artifact.model_facts.name} on ${manifest.clouds.find((cloud) => cloud.slug === artifact.artifact.cloud)?.name || artifact.artifact.cloud} | RunWhere`;
const dataJson = JSON.stringify(artifact).replace(/</g, "\\u003c");
const defaultAssumptions = artifact.options.assumptions;
const escalationUrl = import.meta.env.PUBLIC_ESCALATION_URL || "http://localhost:8080/escalate";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";
const navManifest = {
  models: manifest.models.map((model) => ({
    slug: model.slug,
    name: model.name,
    clouds: model.clouds
  })),
  clouds: manifest.clouds
};
const navManifestJson = JSON.stringify(navManifest).replace(/</g, "\\u003c");

const provenanceEntries = Object.entries(artifact.provenance);
---

<BaseLayout
  title={pageTitle}
  description={`Directional self-host vs hosted API regime for ${artifact.model_facts.name} on ${artifact.artifact.cloud.toUpperCase()}.`}
>
  <article class="artifact page-shell">
    <nav class="knob-panel" aria-label="Composition controls">
      <a class="link-quiet" href="/">RunWhere</a>
      <span aria-hidden="true">/</span>
      <label>
        <span class="visually-hidden">Open-weight model</span>
        <select data-model>
          {manifest.models.map((model) => (
            <option value={model.slug} selected={model.slug === artifact.artifact.model_slug}>{model.name}</option>
          ))}
        </select>
      </label>
      <label>
        <span class="visually-hidden">Cloud</span>
        <select data-cloud>
          {manifest.clouds.map((cloud) => (
            <option value={cloud.slug} selected={cloud.slug === artifact.artifact.cloud}>{cloud.name}</option>
          ))}
        </select>
      </label>
      <label>
        <span class="visually-hidden">GPU</span>
        <select data-gpu>
          {artifact.options.gpus.map((gpu) => (
            <option value={gpu.sku} selected={gpu.sku === artifact.defaults.gpu_sku}>{gpu.sku}</option>
          ))}
        </select>
      </label>
      <div class="quant-row" role="group" aria-label="Quantization">
        {artifact.options.quantizations.map((quant) => (
          <button class="button-chip" type="button" data-quant={quant} aria-pressed={quant === artifact.defaults.quantization ? "true" : "false"}>{quant.toUpperCase()}</button>
        ))}
      </div>
      <label>
        <span class="visually-hidden">Usage shape</span>
        <select data-shape>
          {artifact.options.shapes.map((shape) => (
            <option value={shape.slug} selected={shape.slug === artifact.defaults.shape}>{shape.label}</option>
          ))}
        </select>
      </label>
    </nav>

    <section class="verdict-card" data-verdict-card>
      <p class="eyebrow">Regime</p>
      <h1 data-verdict-title>Loading regime</h1>
      <p data-verdict-copy class="lead"></p>
      <p data-flip-banner class="flip-banner" hidden></p>
    </section>

    <section class="chart-panel panel" aria-labelledby="chart-heading">
      <div class="section-head">
        <div>
          <p class="eyebrow">Crossover</p>
          <h2 id="chart-heading">Monthly cost by tokens per day</h2>
        </div>
        <span class="count-pill mono" data-crossover></span>
      </div>
      <svg data-chart viewBox="0 0 760 360" role="img" aria-labelledby="chart-heading chart-desc">
        <desc id="chart-desc">Self-host and API monthly cost lines across workload levels.</desc>
      </svg>
      <p class="chart-equivalent" data-chart-copy></p>
    </section>

    <section class="breakdown-grid">
      <article class="panel metric-card">
        <p class="eyebrow">Self-host</p>
        <strong data-self-cost></strong>
        <p data-self-details></p>
      </article>
      <article class="panel metric-card">
        <p class="eyebrow">Hosted API</p>
        <strong data-api-cost></strong>
        <p data-api-details></p>
      </article>
    </section>

    <details class="panel assumptions" data-assumptions>
      <summary>
        <span>Assumptions</span>
        <span class="count-pill" data-adjusted-count>defaults</span>
      </summary>
      <div class="assumption-grid">
        <label>
          <span>GPU utilization <output data-utilization-output>{Math.round(defaultAssumptions.utilization * 100)}%</output></span>
          <input type="range" min="30" max="95" value={defaultAssumptions.utilization * 100} data-assumption="utilization" />
        </label>
        <label>
          <span>INT8 multiplier <output data-int8-output>{defaultAssumptions.int8ThroughputMultiplier.toFixed(1)}x</output></span>
          <input type="range" min="1.2" max="2" value={defaultAssumptions.int8ThroughputMultiplier} step="0.1" data-assumption="int8" />
        </label>
        <label>
          <span>INT4 multiplier <output data-int4-output>{defaultAssumptions.int4ThroughputMultiplier.toFixed(1)}x</output></span>
          <input type="range" min="1.5" max="3.5" value={defaultAssumptions.int4ThroughputMultiplier} step="0.1" data-assumption="int4" />
        </label>
        <label>
          <span>Operational labor <output data-fte-output>{defaultAssumptions.fteFraction} FTE</output></span>
          <input type="range" min="0" max="1" value={defaultAssumptions.fteFraction} step="0.05" data-assumption="fte" />
        </label>
        <label>
          <span>Annual salary <output data-salary-output>${Math.round(defaultAssumptions.annualSalaryUsd / 1000)}K</output></span>
          <input type="range" min="50000" max="300000" value={defaultAssumptions.annualSalaryUsd} step="10000" data-assumption="salary" />
        </label>
        <label>
          <span>Peak-to-average <output data-peak-output>{defaultAssumptions.peakToAvgRatio}:1</output></span>
          <input type="range" min="1" max="10" value={defaultAssumptions.peakToAvgRatio} step="0.5" data-assumption="peak" />
        </label>
        <label class="toggle-row">
          <input type="checkbox" data-assumption="overhead" checked={defaultAssumptions.overheadEnabled} />
          <span>Storage/network overhead</span>
        </label>
      </div>
      <button class="button-secondary" type="button" data-reset>Reset to defaults</button>
    </details>

    <section class="panel escalation" data-escalation hidden data-escalation-url={escalationUrl} data-turnstile-site-key={turnstileSiteKey}>
      <div class="escalation-intro">
        <p class="eyebrow" data-escalation-eyebrow>Close call</p>
        <h2 data-escalation-title>Costs are close enough to inspect</h2>
        <p class="muted" data-escalation-copy>Costs are close enough that assumptions could flip the recommendation. RunWhere can hand this composition to a live analysis path.</p>
      </div>
      <div class="escalation-action">
        <button class="button-primary" type="button" data-escalation-btn>Get a tailored recommendation</button>
        <p class="muted escalation-note">Uses this model, cloud, GPU, quantization, and usage shape.</p>
        <div class="escalation-result" data-escalation-result hidden>
          <p class="escalation-text" data-escalation-text></p>
        </div>
        <p class="muted escalation-error" data-escalation-error hidden></p>
      </div>
    </section>

    <section class="provenance panel" aria-labelledby="provenance-heading">
      <p class="eyebrow">Provenance</p>
      <h2 id="provenance-heading">Sources behind this artifact</h2>
      <div class="chip-list">
        {provenanceEntries.map(([key, item]) => (
          <a class={`prov-chip prov-${item.label}`} href={item.url} title={`${key}: ${item.source}`}>
            {item.label}: {item.source}
          </a>
        ))}
      </div>
      <p class="muted mono">Artifact {artifact.artifact.id} - ruleset {artifact.artifact.ruleset_version}</p>
    </section>
  </article>

  <script id="artifact-data" type="application/json" is:inline set:html={dataJson}></script>
  <script id="nav-manifest-data" type="application/json" is:inline set:html={navManifestJson}></script>
  <script is:inline>
    const artifact = JSON.parse(document.getElementById("artifact-data").textContent);
    const navManifest = JSON.parse(document.getElementById("nav-manifest-data").textContent);
    const params = new URL(location.href).searchParams;
    const state = {
      gpu: params.get("gpu") || artifact.defaults.gpu_sku,
      quant: params.get("quant") || artifact.defaults.quantization,
      shape: params.get("shape") || artifact.defaults.shape
    };
    const artifactDefaults = artifact.options.assumptions;
    const defaults = {
      utilization: artifactDefaults.utilization,
      int8: artifactDefaults.int8ThroughputMultiplier,
      int4: artifactDefaults.int4ThroughputMultiplier,
      fte: artifactDefaults.fteFraction,
      salary: artifactDefaults.annualSalaryUsd,
      peak: artifactDefaults.peakToAvgRatio,
      overhead: artifactDefaults.overheadEnabled
    };
    const assumptions = { ...defaults };
    const regimeThreshold = artifact.options.regime_threshold;

    const $ = (selector) => document.querySelector(selector);
    const money = (value) =>
      value == null || !Number.isFinite(value)
        ? "Infeasible"
        : new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
            maximumFractionDigits: 0
          }).format(value);
    const compact = (value) =>
      new Intl.NumberFormat("en-US", { notation: "compact", maximumFractionDigits: 1 }).format(value);

    function key() {
      return `${state.gpu}__${state.quant}__${state.shape}`;
    }

    function selectedComposition() {
      return artifact.compositions[key()] || artifact.compositions[`${artifact.defaults.gpu_sku}__${artifact.defaults.quantization}__${artifact.defaults.shape}`];
    }

    function classify(selfCost, apiCost) {
      if (!Number.isFinite(selfCost)) return "api-wins";
      const ratio = Math.max(selfCost, apiCost) / Math.min(selfCost, apiCost);
      if (ratio < regimeThreshold) return "close-call";
      return selfCost < apiCost ? "self-host-wins" : "api-wins";
    }

    function apiAggregateTps() {
      return artifact.api_side.throughput_p50_tps * artifact.api_side.providers_count;
    }

    function apiCapacityFor(peakOutputTps) {
      const aggregate = apiAggregateTps();
      return {
        aggregate_p50_tps: aggregate,
        required_peak_output_tps: Math.round(peakOutputTps),
        constrained: aggregate > 0 && peakOutputTps > aggregate
      };
    }

    function applyServingNuance(costRegime, fits, apiCapacity) {
      if (costRegime === "api-wins" && fits && apiCapacity.constrained) return "close-call";
      return costRegime;
    }

    function escalationTrigger(computed) {
      if (computed.costRegime === "close-call") {
        return {
          kind: "close-call",
          eyebrow: "Close call",
          title: "Costs are close enough to inspect",
          copy: `The modeled monthly costs are only ${computed.ratio?.toFixed(1) || "~1"}x apart (${money(computed.selfCost)} self-host vs ${money(computed.apiCost)} API). A tailored read can check whether quality, operations, or assumptions would flip this.`
        };
      }

      if (computed.costRegime === "api-wins" && computed.fits && computed.apiCapacity.constrained) {
        return {
          kind: "capacity-caveat",
          eyebrow: "Capacity caveat",
          title: "API is cheaper, but capacity needs a check",
          copy: `API is still the cheaper cost path, but estimated peak output demand (${compact(computed.apiCapacity.required_peak_output_tps)} tokens/sec) is above measured hosted aggregate p50 capacity (${compact(computed.apiCapacity.aggregate_p50_tps)} tokens/sec). A tailored read can check quotas, latency, and routing risk.`
        };
      }

      return null;
    }

    function selfHostForTokens(input, tokensPerDay) {
      const quantization = input.quantization || state.quant;
      const defaultMultiplier = quantization === "int8" ? defaults.int8 : quantization === "int4" ? defaults.int4 : 1;
      const activeMultiplier = quantization === "int8" ? assumptions.int8 : quantization === "int4" ? assumptions.int4 : 1;
      const perGpuTps = input.self_host_throughput_tps_per_gpu / defaultMultiplier * activeMultiplier * (assumptions.utilization / defaults.utilization);
      const peakTps = (tokensPerDay / 86400) * assumptions.peak;
      const peakOutputTps = (tokensPerDay * artifactDefaults.outputShare / 86400) * assumptions.peak;
      const vramGpuCount = Math.max(1, Math.ceil(input.vram_required_gb / input.gpu_memory_gb));
      const capacityGpuCount = Math.max(1, Math.ceil(peakOutputTps / perGpuTps));
      const gpuCount = Math.max(vramGpuCount, capacityGpuCount);
      const fits = gpuCount <= input.gpu_max_count;
      const labor = assumptions.fte * assumptions.salary / 12;
      const baseCost = fits ? (input.gpu_price_hourly_usd * gpuCount * 24 * 30) + labor : Infinity;
      const selfCost = assumptions.overhead ? baseCost * 1.08 : baseCost;

      return { fits, selfCost, gpuCount, perGpuTps, peakTps, peakOutputTps };
    }

    function crossoverForSelfCost(selfCost) {
      const blendedPrice =
        artifactDefaults.inputShare * artifact.api_side.price_input_per_mtok_usd +
        artifactDefaults.outputShare * artifact.api_side.price_output_per_mtok_usd;

      if (!Number.isFinite(selfCost) || blendedPrice <= 0) return null;
      return (selfCost / blendedPrice / 30) * 1_000_000;
    }

    function recompute(composition) {
      const input = composition.inputs;
      const host = selfHostForTokens(input, input.tokens_per_day);
      const apiCost = composition.api_monthly_usd;
      const costRegime = classify(host.selfCost, apiCost);
      const apiCapacity = apiCapacityFor(host.peakOutputTps);
      const regime = applyServingNuance(costRegime, host.fits, apiCapacity);
      const ratio = Number.isFinite(host.selfCost) && apiCost > 0 ? Math.max(host.selfCost, apiCost) / Math.min(host.selfCost, apiCost) : null;
      const crossoverTokens = crossoverForSelfCost(host.selfCost);

      return { ...composition, ...host, apiCost, costRegime, apiCapacity, regime, ratio, crossoverTokens };
    }

    function regimeTitle(regime) {
      if (regime === "self-host-wins") return "Self-host wins clearly";
      if (regime === "api-wins") return "API wins clearly";
      return "Close call";
    }

    function updateUrl() {
      const params = new URLSearchParams();
      if (state.gpu !== artifact.defaults.gpu_sku) params.set("gpu", state.gpu);
      if (state.quant !== artifact.defaults.quantization) params.set("quant", state.quant);
      if (state.shape !== artifact.defaults.shape) params.set("shape", state.shape);
      history.replaceState(null, "", `${location.pathname}${params.toString() ? `?${params}` : ""}`);
    }

    function updateControls() {
      $("[data-model]").value = artifact.artifact.model_slug;
      $("[data-cloud]").value = artifact.artifact.cloud;
      syncCloudOptions(artifact.artifact.model_slug);
      $("[data-gpu]").value = state.gpu;
      $("[data-shape]").value = state.shape;
      document.querySelectorAll("[data-quant]").forEach((button) => {
        button.setAttribute("aria-pressed", button.dataset.quant === state.quant ? "true" : "false");
      });
    }

    function supportedCloudsFor(modelSlug) {
      return navManifest.models.find((model) => model.slug === modelSlug)?.clouds || [];
    }

    function syncCloudOptions(modelSlug) {
      const supportedClouds = supportedCloudsFor(modelSlug);
      document.querySelectorAll("[data-cloud] option").forEach((option) => {
        option.disabled = supportedClouds.length > 0 && !supportedClouds.includes(option.value);
      });
    }

    function navigateToComposition(modelSlug, cloudSlug) {
      location.href = `/run/${modelSlug}/${cloudSlug}/`;
    }

    function drawChart(composition, computed) {
      const svg = $("[data-chart]");
      const width = 760;
      const height = 360;
      const pad = { left: 70, right: 24, top: 24, bottom: 56 };
      const points = composition.crossover_series;
      const minX = 100000;
      const maxX = 5000000000;
      const allApiCosts = points.map((point) => point.api_usd);
      const visibleCosts = allApiCosts.filter((v) => v > 0);
      const selfSeries = points
        .map((point) => {
          const host = selfHostForTokens(composition.inputs, point.tokens_per_day);
          return host.fits ? { tokens_per_day: point.tokens_per_day, value: host.selfCost } : null;
        })
        .filter(Boolean);
      visibleCosts.push(...selfSeries.map((point) => point.value).filter((v) => v > 0));
      const minY = Math.max(10, Math.min(...visibleCosts) * 0.65);
      const maxY = Math.max(...visibleCosts) * 1.35;
      const log = Math.log10;
      const x = (value) => pad.left + ((log(value) - log(minX)) / (log(maxX) - log(minX))) * (width - pad.left - pad.right);
      const y = (value) => height - pad.bottom - ((log(value) - log(minY)) / (log(maxY) - log(minY))) * (height - pad.top - pad.bottom);
      const path = (series) => series.map((point, index) => `${index ? "L" : "M"} ${x(point.tokens_per_day)} ${y(point.value)}`).join(" ");
      const apiSeries = points.map((point) => ({ tokens_per_day: point.tokens_per_day, value: point.api_usd }));
      const selfValue = Number.isFinite(computed.selfCost) ? computed.selfCost : null;
      const workloadX = x(composition.inputs.tokens_per_day);
      const yTicks = [100, 1000, 10000, 100000, 1000000].filter((tick) => tick >= minY && tick <= maxY);
      const xTicks = [100000, 1000000, 10000000, 100000000, 1000000000];

      svg.innerHTML = `
        <rect x="0" y="0" width="${width}" height="${height}" fill="transparent"></rect>
        ${xTicks.map((tick) => `<line x1="${x(tick)}" x2="${x(tick)}" y1="${pad.top}" y2="${height - pad.bottom}" stroke="var(--color-border-muted)"></line><text x="${x(tick)}" y="${height - 20}" text-anchor="middle">${compact(tick)}</text>`).join("")}
        ${yTicks.map((tick) => `<line x1="${pad.left}" x2="${width - pad.right}" y1="${y(tick)}" y2="${y(tick)}" stroke="var(--color-border-muted)"></line><text x="12" y="${y(tick) + 4}">${money(tick).replace(".00", "")}</text>`).join("")}
        ${selfSeries.length ? `<path d="${path(selfSeries)}" fill="none" stroke="var(--color-regime-self-host)" stroke-width="3"></path>` : ""}
        <path d="${path(apiSeries)}" fill="none" stroke="var(--color-regime-api)" stroke-width="3"></path>
        <line x1="${workloadX}" x2="${workloadX}" y1="${pad.top}" y2="${height - pad.bottom}" stroke="var(--color-fg-muted)" stroke-dasharray="6 6"></line>
        <circle cx="${workloadX}" cy="${y(Math.max(1, computed.apiCost))}" r="5" fill="var(--color-regime-api)"></circle>
        ${selfValue != null ? `<circle cx="${workloadX}" cy="${y(Math.max(1, selfValue))}" r="5" fill="var(--color-regime-self-host)"></circle>` : ""}
        <text x="${pad.left}" y="${height - 342}" fill="var(--color-regime-self-host)">Self-host</text>
        <text x="${pad.left + 92}" y="${height - 342}" fill="var(--color-regime-api)">API</text>
      `;
    }

    function updateAssumptionLabels() {
      $("[data-utilization-output]").textContent = `${Math.round(assumptions.utilization * 100)}%`;
      $("[data-int8-output]").textContent = `${assumptions.int8.toFixed(1)}x`;
      $("[data-int4-output]").textContent = `${assumptions.int4.toFixed(1)}x`;
      $("[data-fte-output]").textContent = `${assumptions.fte.toFixed(2).replace(/0$/, "")} FTE`;
      $("[data-salary-output]").textContent = `$${Math.round(assumptions.salary / 1000)}K`;
      $("[data-peak-output]").textContent = `${assumptions.peak}:1`;
      const adjusted = Object.entries(assumptions).filter(([name, value]) => value !== defaults[name]).length;
      $("[data-adjusted-count]").textContent = adjusted ? `${adjusted} adjusted` : "defaults";
    }

    function syncAssumptionInputs() {
      document.querySelector('[data-assumption="utilization"]').value = String(defaults.utilization * 100);
      document.querySelector('[data-assumption="int8"]').value = String(defaults.int8);
      document.querySelector('[data-assumption="int4"]').value = String(defaults.int4);
      document.querySelector('[data-assumption="fte"]').value = String(defaults.fte);
      document.querySelector('[data-assumption="salary"]').value = String(defaults.salary);
      document.querySelector('[data-assumption="peak"]').value = String(defaults.peak);
      document.querySelector('[data-assumption="overhead"]').checked = defaults.overhead;
    }

    function render() {
      const composition = selectedComposition();
      const computed = recompute(composition);
      const defaultRegime = composition.regime;
      const ratioCopy = computed.ratio ? `${computed.ratio.toFixed(1)}x difference` : "self-host infeasible";

      updateControls();
      updateAssumptionLabels();
      $("[data-verdict-card]").dataset.regime = computed.regime;
      $("[data-verdict-title]").textContent = `${computed.regime === "close-call" ? "~" : "Clear:"} ${regimeTitle(computed.regime)}`;

      let verdictCopy;
      if (computed.regime === "close-call") {
        if (computed.costRegime === "api-wins" && computed.apiCapacity.constrained) {
          verdictCopy = `API is ${computed.ratio?.toFixed(1)}x cheaper on token cost, but peak output demand (${compact(computed.apiCapacity.required_peak_output_tps)} tokens/sec) exceeds measured hosted aggregate p50 (${compact(computed.apiCapacity.aggregate_p50_tps)} tokens/sec). Capacity and latency likely dominate.`;
        } else {
          verdictCopy = `${ratioCopy}; operational preferences likely dominate.`;
        }
      } else if (computed.regime === "api-wins") {
        const crossover = computed.crossoverTokens;
        const crossoverNote = crossover
          ? ` Self-hosting breaks even around ${compact(crossover)} blended tokens/day at this capacity point.`
          : " Self-hosting is not cost-competitive at any modelled scale.";
        verdictCopy = `API is cheaper at ${compact(composition.inputs.tokens_per_day)} blended tokens/day.${crossoverNote}`;
      } else {
        verdictCopy = `Self-host is cheaper at ${compact(composition.inputs.tokens_per_day)} blended tokens/day.`;
      }
      $("[data-verdict-copy]").textContent = verdictCopy;

      const flip = $("[data-flip-banner]");
      if (defaultRegime !== computed.regime) {
        flip.hidden = false;
        flip.textContent = `With your adjustments, this becomes ${regimeTitle(computed.regime).toLowerCase()}. Defaults called it ${regimeTitle(defaultRegime).toLowerCase()}.`;
      } else {
        flip.hidden = true;
      }

      $("[data-self-cost]").textContent = money(computed.selfCost);
      $("[data-self-details]").textContent = computed.fits
        ? `${computed.gpuCount}x ${composition.inputs.gpu_name} - ${Math.round(computed.perGpuTps * computed.gpuCount)} output tokens/sec - ${composition.inputs.instance_type}`
        : composition.reason;
      $("[data-api-cost]").textContent = money(computed.apiCost);
      $("[data-api-details]").textContent = `${artifact.api_side.providers_count} providers - ${compact(computed.apiCapacity.aggregate_p50_tps)} aggregate p50 output tokens/sec - peak output demand ${compact(computed.apiCapacity.required_peak_output_tps)} - ${artifact.api_side.price_input_per_mtok_usd}/${artifact.api_side.price_output_per_mtok_usd} USD per MTok`;
      $("[data-crossover]").textContent = computed.crossoverTokens
        ? `Cost break-even at ${compact(computed.crossoverTokens)} tok/day`
        : "no crossover in range";
      const capacityCopy = computed.apiCapacity.constrained
        ? ` Hosted API peak capacity is constrained at this output rate.`
        : ` Hosted API aggregate p50 capacity covers the estimated peak output rate.`;
      $("[data-chart-copy]").textContent = `At ${compact(composition.inputs.tokens_per_day)} blended tokens/day: self-host ${money(computed.selfCost)}/month, API ${money(computed.apiCost)}/month. Peak output demand is ${compact(computed.apiCapacity.required_peak_output_tps)} tokens/sec.${capacityCopy}`;

      const trigger = escalationTrigger(computed);
      const escalation = $("[data-escalation]");
      escalation.hidden = !trigger;
      if (trigger) {
        escalation.dataset.trigger = trigger.kind;
        $("[data-escalation-eyebrow]").textContent = trigger.eyebrow;
        $("[data-escalation-title]").textContent = trigger.title;
        $("[data-escalation-copy]").textContent = trigger.copy;
      }

      drawChart(composition, computed);
      updateUrl();
    }

    $("[data-gpu]").addEventListener("change", (event) => {
      state.gpu = event.target.value;
      render();
    });
    $("[data-shape]").addEventListener("change", (event) => {
      state.shape = event.target.value;
      render();
    });
    $("[data-model]").addEventListener("change", (event) => {
      const nextModel = event.target.value;
      const currentCloud = $("[data-cloud]").value || artifact.artifact.cloud;
      const supportedClouds = supportedCloudsFor(nextModel);
      const nextCloud = supportedClouds.includes(currentCloud) ? currentCloud : supportedClouds[0] || artifact.artifact.cloud;
      navigateToComposition(nextModel, nextCloud);
    });
    $("[data-cloud]").addEventListener("change", (event) => {
      navigateToComposition(artifact.artifact.model_slug, event.target.value);
    });
    document.querySelectorAll("[data-quant]").forEach((button) => {
      button.addEventListener("click", () => {
        state.quant = button.dataset.quant;
        render();
      });
    });
    document.querySelectorAll("[data-assumption]").forEach((input) => {
      input.addEventListener("input", () => {
        const kind = input.dataset.assumption;
        if (kind === "utilization") assumptions.utilization = Number(input.value) / 100;
        if (kind === "int8") assumptions.int8 = Number(input.value);
        if (kind === "int4") assumptions.int4 = Number(input.value);
        if (kind === "fte") assumptions.fte = Number(input.value);
        if (kind === "salary") assumptions.salary = Number(input.value);
        if (kind === "peak") assumptions.peak = Number(input.value);
        if (kind === "overhead") assumptions.overhead = input.checked;
        render();
      });
    });
    $("[data-reset]").addEventListener("click", () => {
      Object.assign(assumptions, defaults);
      syncAssumptionInputs();
      render();
    });

    const escalationSection = $("[data-escalation]");
    const escalationBtn = $("[data-escalation-btn]");

    function loadTurnstile() {
      if (window.turnstile) return Promise.resolve(window.turnstile);
      return new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
        script.async = true;
        script.defer = true;
        script.onload = () => resolve(window.turnstile);
        script.onerror = () => reject(new Error("Turnstile failed to load"));
        document.head.appendChild(script);
      });
    }

    async function getTurnstileToken() {
      const siteKey = escalationSection?.dataset.turnstileSiteKey;
      if (!siteKey) return undefined;
      const turnstile = await loadTurnstile();
      return await new Promise((resolve, reject) => {
        const container = document.createElement("div");
        document.body.appendChild(container);
        const timeout = setTimeout(() => reject(new Error("Turnstile timed out")), 15000);
        const widgetId = turnstile.render(container, {
          sitekey: siteKey,
          size: "invisible",
          callback: (token) => {
            clearTimeout(timeout);
            container.remove();
            resolve(token);
          },
          "error-callback": () => {
            clearTimeout(timeout);
            container.remove();
            reject(new Error("Turnstile challenge failed"));
          }
        });
        turnstile.execute(widgetId);
      });
    }

    escalationBtn?.addEventListener("click", async () => {
      const url = escalationSection?.dataset.escalationUrl;
      const resultEl = $("[data-escalation-result]");
      const textEl = $("[data-escalation-text]");
      const errorEl = $("[data-escalation-error]");

      escalationBtn.disabled = true;
      escalationBtn.textContent = "Analysing…";
      resultEl.hidden = false;
      errorEl.hidden = true;
      textEl.textContent = "";

      try {
        const turnstileToken = await getTurnstileToken();
        const response = await fetch(url, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            artifact_id: artifact.artifact.id,
            flow: "advanced",
            outcome: selectedComposition().regime,
            model_slug: artifact.artifact.model_slug,
            cloud: artifact.artifact.cloud,
            composition_key: key(),
            inputs: {},
            turnstile_token: turnstileToken
          })
        });

        if (!response.ok) {
          const err = await response.json().catch(() => ({}));
          throw new Error(err.error || `Server error ${response.status}`);
        }

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        let currentEvent = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });

          const lines = buffer.split("\n");
          buffer = lines.pop() ?? "";

          for (const line of lines) {
            if (line.startsWith("event: ")) {
              currentEvent = line.slice(7).trim();
            } else if (line.startsWith("data: ") && currentEvent === "chunk") {
              try {
                const data = JSON.parse(line.slice(6));
                if (data.text) textEl.textContent += data.text;
              } catch {}
            } else if (line === "") {
              currentEvent = "";
            }
          }
        }

        escalationBtn.textContent = "Run again";
        escalationBtn.disabled = false;
      } catch (err) {
        resultEl.hidden = true;
        errorEl.hidden = false;
        errorEl.textContent = err?.message || "Analysis unavailable. Check that the escalation service is running.";
        escalationBtn.textContent = "Try again";
        escalationBtn.disabled = false;
      }
    });

    render();
  </script>
</BaseLayout>

