---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Changelog | RunWhere" description="RunWhere release notes.">
  <article class="prose page-shell-narrow">
    <header>
      <p class="eyebrow">Changelog</p>
      <h1 class="page-title">Release notes</h1>
    </header>
    <section>
      <h2>0.1.0</h2>
      <p>
        Initial Astro implementation: API-first homepage, four-question outlier check, boundary artifact, serving modality
        comparison, model and GPU catalogs, advanced generated artifacts, methodology, and escalation surface.
      </p>
    </section>
  </article>
</BaseLayout>
