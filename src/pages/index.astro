---
import BaseLayout from "../layouts/BaseLayout.astro";
import manifest from "../data/generated/manifest.json";

const defaultModel = manifest.models[0];
const defaultCloud = manifest.clouds[0];
const defaultShape = manifest.shapes.find((shape) => shape.slug === "medium") || manifest.shapes[0];
---

<BaseLayout
  title="RunWhere | Self-host or stay on the API?"
  description="Choose an open-weight model, cloud, and usage shape. RunWhere returns the directional cost regime with assumptions and sources visible."
>
  <section class="home page-shell">
    <div class="hero">
      <div>
        <h1>Self-host or stay on the API?</h1>
        <p class="hero-copy">
          Choose a model, cloud, and usage shape. Get a directional cost regime with assumptions and sources visible.
        </p>
      </div>
    </div>

    <form class="composer panel" data-composer>
      <div class="composer-body">
        <section class="model-section" aria-labelledby="model-heading">
          <div class="section-head">
            <h2 id="model-heading">Model</h2>
            <span class="count-pill" data-count>{manifest.models.length} models</span>
          </div>

          <div class="model-list" role="radiogroup" aria-label="Models">
            {manifest.models.map((model, index) => (
              <label
                class="model-option interactive-panel"
                data-model-card
              >
                <input
                  type="radio"
                  name="model"
                  value={model.slug}
                  checked={index === 0}
                  data-model-input
                />
                <span>
                  <strong>{model.name}</strong>
                  <span>{model.vendor} · {model.params_b}B params</span>
                </span>
              </label>
            ))}
          </div>
        </section>

        <div class="right-panel">
          <section aria-labelledby="cloud-heading">
            <h2 id="cloud-heading">Cloud</h2>
            <div class="segmented" role="radiogroup" aria-label="Cloud">
              {manifest.clouds.map((cloud, index) => (
                <label class="segment">
                  <input type="radio" name="cloud" value={cloud.slug} checked={index === 0} />
                  <span>{cloud.name}</span>
                </label>
              ))}
            </div>
          </section>

          <section aria-labelledby="shape-heading">
            <h2 id="shape-heading">Usage shape</h2>
            <div class="shape-grid" role="radiogroup" aria-label="Usage shape">
              {manifest.shapes.map((shape) => (
                <label class="shape-card interactive-panel">
                  <input type="radio" name="shape" value={shape.slug} checked={shape.slug === defaultShape.slug} />
                  <span class="shape-label">{shape.label}</span>
                  <strong>{Intl.NumberFormat("en", { notation: "compact" }).format(shape.tokens_per_day)} tokens/day</strong>
                  <span>{shape.persona}</span>
                </label>
              ))}
            </div>
          </section>

          <div class="composer-actions">
            <a class="button-primary" href={`/run/${defaultModel.slug}/${defaultCloud.slug}/?shape=${defaultShape.slug}`} data-submit>
              Show regime &rarr;
            </a>
            <p class="request-line">
              Don't see your model? <a href="https://github.com/RunWhere/web/issues/new?title=Model%20request%3A%20&labels=model-request">Request it on GitHub</a>.
            </p>
          </div>
        </div>
      </div>
    </form>

    <section class="home-notes">
      <article>
        <p class="eyebrow">Versioned artifacts</p>
        <h2>Build-time results.</h2>
        <p>Each model–cloud page is a versioned artifact generated at build time, with a ruleset version and source timestamps.</p>
      </article>
      <article>
        <p class="eyebrow">Adjustable assumptions</p>
        <h2>Opinions stay visible.</h2>
        <p>Utilisation, labour, traffic shape, and quantisation multipliers are adjustable without changing the canonical URL.</p>
      </article>
      <article>
        <p class="eyebrow">Escalation</p>
        <h2>Only close calls need live analysis.</h2>
        <p>Clear regimes are deterministic. Boundary cases expose an opt-in live analysis path.</p>
      </article>
    </section>
  </section>

  <script is:inline>
    const composer = document.querySelector("[data-composer]");
    const cards = Array.from(document.querySelectorAll("[data-model-card]"));
    const submit = document.querySelector("[data-submit]");

    function selected(name) {
      return composer?.querySelector(`input[name="${name}"]:checked`)?.value;
    }

    function updateHref() {
      const model = selected("model");
      const cloud = selected("cloud");
      const shape = selected("shape");
      if (submit && model && cloud && shape) {
        submit.href = `/run/${model}/${cloud}/?shape=${shape}`;
      }
    }

    composer?.addEventListener("change", updateHref);
    updateHref();
  </script>
</BaseLayout>

<style>
  .home {
    padding-bottom: var(--space-8);
  }

  .hero {
    padding-block: var(--space-6);
  }

  .hero h1 {
    font-size: var(--text-2xl);
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 720px) {
    .hero h1 {
      font-size: var(--text-3xl);
    }
  }

  .hero .hero-copy {
    font-size: var(--text-base);
    margin: 0;
  }

  .composer {
    padding: var(--space-4);
  }

  .composer-body {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 860px) {
    .composer-body {
      grid-template-columns: 1fr 320px;
    }
  }

  .model-section,
  .right-panel {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .composer h2 {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    letter-spacing: 0.1em;
  }

  .count-pill {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-subtle);
    padding: 0.25rem 0.6rem;
    color: var(--color-fg-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    white-space: nowrap;
  }

  .model-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
  }

  .model-option {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2);
    padding: var(--space-3);
    cursor: pointer;
  }

  .model-option input {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
    flex-shrink: 0;
  }

  .model-option span {
    display: grid;
    gap: 0.1rem;
  }

  .model-option strong {
    font-size: var(--text-sm);
    line-height: 1.3;
  }

  .model-option span span {
    display: block;
    color: var(--color-fg-muted);
    font-size: var(--text-xs);
  }

  .segmented {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .segment {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.45rem 0.7rem;
    background: var(--color-surface);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  .segment input {
    accent-color: var(--color-accent);
  }

  .shape-grid {
    display: grid;
    gap: var(--space-2);
  }

  .shape-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2);
    padding: var(--space-3);
    cursor: pointer;
  }

  .shape-card input {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
  }

  .shape-card span,
  .shape-card strong {
    display: block;
    font-size: var(--text-sm);
  }

  .shape-label {
    color: var(--color-fg-default);
    font-weight: 700;
  }

  .shape-card strong {
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .shape-card span:not(.shape-label) {
    color: var(--color-fg-muted);
    font-size: var(--text-xs);
  }

  .composer-actions {
    display: grid;
    gap: var(--space-3);
  }

  .button-primary {
    width: 100%;
    justify-content: center;
  }

  .request-line {
    color: var(--color-fg-muted);
    font-size: var(--text-xs);
    text-align: center;
  }

  .home-notes {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-12);
    border-top: 1px solid var(--color-border-muted);
    padding-top: var(--space-8);
  }

  .home-notes article {
    display: grid;
    gap: var(--space-2);
  }

  .home-notes h2 {
    font-size: var(--text-lg);
    font-weight: 650;
    letter-spacing: 0;
  }

  .home-notes p:not(.eyebrow) {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    .home-notes {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
