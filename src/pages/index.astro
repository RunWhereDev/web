---
import BaseLayout from "../layouts/BaseLayout.astro";
import manifest from "../data/generated/manifest.json";

const defaultModel = manifest.models[0];
const defaultCloud = manifest.clouds[0];
const headline = manifest.headline;
const refreshDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
}).format(new Date(manifest.refresh.pricing_last_run));
---

<BaseLayout
  title="RunWhere | Stay on the API unless you're the exception"
  description="RunWhere gives the API-first answer instantly, then checks whether your workload belongs in the self-hosting exception set."
>
  <section class="home page-shell">
    <div class="hero hero-grid">
      <div class="hero-copy-block">
        <p class="eyebrow">API-first by default</p>
        <h1><a href={headline.methodology_url}>{headline.label}.</a></h1>
        <p class="hero-copy">
          At typical scale, hosted API providers compete hard enough on price that self-hosting usually loses — and that is before counting your time.
          But exceptions exist.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button-primary" href="/check/">Check if I'm the exception →</a>
          <a class="button-secondary" href={`/run/${defaultModel.slug}/${defaultCloud.slug}/`}>
            I already know my open-weight model
          </a>
        </div>
      </div>

      <aside class="headline-card panel" aria-labelledby="trust-heading">
        <p class="eyebrow">Headline provenance</p>
        <h2 id="trust-heading">Computed, not hard-coded.</h2>
        <dl>
          <div>
            <dt>API-first rate</dt>
            <dd>{Math.round(headline.api_first_rate * 100)}%</dd>
          </div>
          <div>
            <dt>Pricing refresh</dt>
            <dd>{refreshDate}</dd>
          </div>
          <div>
            <dt>Ruleset</dt>
            <dd>{manifest.ruleset_version}</dd>
          </div>
        </dl>
        <a href="/methodology/#headline-rate">See the reference workload math</a>
      </aside>
    </div>

    <section class="exception-panel panel" aria-labelledby="exceptions-heading">
      <div>
        <p class="eyebrow">Exception traits</p>
        <h2 id="exceptions-heading">Check if any of these apply.</h2>
      </div>
      <ul class="exception-list">
        <li>Sustained high-volume API spend</li>
        <li>Strict data residency or air-gap requirements</li>
        <li>Predictable batch or steady GPU utilization</li>
        <li>Small open-weight substitute is acceptable</li>
        <li>Latency requirements API providers cannot meet</li>
      </ul>
    </section>

    <section class="home-notes" aria-label="How RunWhere works">
      <article>
        <p class="eyebrow">Four questions</p>
        <h2>No parameter anxiety.</h2>
        <p>The primary flow asks only for API spend band, hosted model, traffic shape, and hard constraints.</p>
      </article>
      <article>
        <p class="eyebrow">Serving modalities</p>
        <h2>Self-hosting is not one thing.</h2>
        <p>Exception results compare API, managed endpoints, serverless GPU, VMs, batch GPU, and owned hardware.</p>
      </article>
      <article>
        <p class="eyebrow">Advanced path</p>
        <h2>Open-weight details stay available.</h2>
        <p>If you already know the model and cloud, inspect the precomputed GPU × quantization × shape matrix.</p>
      </article>
    </section>
  </section>
</BaseLayout>

<style>
  .home {
    padding-bottom: var(--space-8);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1fr);
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) 360px;
    }
  }

  .hero-copy-block {
    display: grid;
    align-content: center;
    gap: var(--space-4);
  }

  .hero h1 a {
    color: inherit;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.12em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .headline-card,
  .exception-panel {
    padding: var(--space-6);
  }

  .headline-card {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .headline-card h2,
  .exception-panel h2,
  .home-notes h2 {
    font-size: var(--text-xl);
    letter-spacing: 0;
  }

  .headline-card dl {
    display: grid;
    gap: var(--space-3);
    margin: 0;
  }

  .headline-card dl div {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: var(--space-2);
  }

  .headline-card dt {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  .headline-card dd {
    margin: 0;
    font-weight: 700;
  }

  .exception-panel {
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 860px) {
    .exception-panel {
      grid-template-columns: 0.8fr 1.2fr;
      align-items: start;
    }
  }

  .exception-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .exception-list li {
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    padding: var(--space-3);
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    font-weight: 650;
  }

  .home-notes {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-12);
    border-top: 1px solid var(--color-border-muted);
    padding-top: var(--space-8);
  }

  .home-notes article {
    display: grid;
    gap: var(--space-2);
  }

  .home-notes p:not(.eyebrow) {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    .home-notes {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>